{
    "name": "chip/interest_account",
    "type": "library",
    "version": "0.1.0",
    "authors": [
        {
            "name": "Gabor Jonas",
            "email": "gaborjonas8813@gmail.com"
        }
    ],
    "require": {
        "php": "~8.5.0",
        "ext-bcmath": "*",
        "ext-uuid": "*",
        "symfony/clock": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/uid": "^8.0"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.50",
        "friendsofphp/php-cs-fixer": "^3.94",
        "infection/infection": "^0.32.5",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.0"
    },
    "replace": {
        "symfony/polyfill-uuid": "*"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Chip\\InterestAccount\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "check": [
            "@lint",
            "@stan",
            "@test",
            "@mutation"
        ],
        "lint": "php-cs-fixer fix --diff",
        "lint:check": "php-cs-fixer check --diff",
        "mutation": "infection",
        "stan": "phpstan analyze",
        "test": "XDEBUG_MODE=coverage phpunit --coverage-html ./temp/phpunit/coverage --cache-directory ./temp/phpunit/cache"
    },
    "scripts-descriptions": {
        "check": "Run all quality assurance checks (lint, stan, test, mutation)",
        "lint": "Fix code style issues automatically",
        "lint:check": "Check code style without fixing issues",
        "mutation": "Run mutation testing with Infection",
        "stan": "Run static analysis with PHPStan",
        "test": "Run unit tests with PHPUnit"
    }
}
